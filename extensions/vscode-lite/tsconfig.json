{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "out/tsc",
    "sourceMap": true,
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["mocha"]
  },
  "include": ["src/**/*", "vitest.config.ts"],
  "exclude": ["node_modules", "out", "build", "e2e/_output"]
}

